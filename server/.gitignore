.env
package-lock.json
# Dependencies
node_modules/
/jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Environment variable files
.env
.env.*
!.env.example

# TypeScript cache
*.tsbuildinfo

# Node-waf configure output
.lock-wscript

# Compiled binary addons
build/Release/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.log/

# IDEs and other tools (optional, consider a global gitignore for these)
.vscode/
.idea/
.cache/
.parcel-cache/
.next/
dist/
